# ──────────────────────────────────────────────────────────
# OpenStock – environment variable reference
# Copy to .env.local and fill in real values.
# Never commit .env.local (already gitignored).
# ──────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────
# MongoDB Atlas connection string (required)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=

# ── Auth (better-auth) ─────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
# Base URL of the app (e.g. http://localhost:3000 locally, https://your-domain.com in prod)
BETTER_AUTH_URL=http://localhost:3000

# ── Email (Nodemailer / Gmail) ─────────────────────────────
# Use a Gmail App Password, NOT your regular Gmail password
# https://myaccount.google.com/apppasswords
NODEMAILER_EMAIL=
NODEMAILER_PASSWORD=

# ── AI provider ────────────────────────────────────────────
# Default provider is "gemini". Set AI_PROVIDER to switch (gemini | minimax | siray).
AI_PROVIDER=gemini

# Google Gemini (default)
GEMINI_API_KEY=
# Override model (default: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# MiniMax (optional fallback / alternative)
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2.7

# Siray (optional fallback / alternative)
# SIRAY_API_KEY=

# ── Background jobs (Inngest) ──────────────────────────────
# Required only for Vercel / production deployments
INNGEST_SIGNING_KEY=

# ── Sentiment data (Adanos) ────────────────────────────────
# Optional – enables Reddit/X/News/Polymarket sentiment panel
# ADANOS_API_KEY=
# ADANOS_API_BASE_URL=https://api.adanos.org

# ── Deprecated ─────────────────────────────────────────────
# NEXT_PUBLIC_FINNHUB_API_KEY – removed; stock data now uses yahoo-finance2 (no key needed)
# FINNHUB_BASE_URL             – removed
